# IKEA environment
IKEA_ENV=dev
IKEA_TENANT=ikea
TENANT_NAME=ikea
ENVIRONMENT=dev

# Override in qa/prod deployments
# IKEA_ENV=qa
# IKEA_ENV=prod

# Databricks
DATABRICKS_HOST=https://adb-xxxxxxxxxx.xx.azuredatabricks.net
DATABRICKS_WORKSPACE_ID=1234567890123456
UC_CATALOG=main
UC_BRONZE_SCHEMA=bronze
UC_SILVER_SCHEMA=silver
UC_AUDIT_SCHEMA=audit
UC_CONTROL_SCHEMA=control
CHECKPOINT_ROOT=/Volumes/main/system/checkpoints
SCHEMA_TRACKING_ROOT=/Volumes/main/system/schema_tracking
UC_EXTERNAL_LOCATION=abfss://rngpub@adlsdnapdevsilver.dfs.core.windows.net/eng511/
UC_USE_EXTERNAL_LOCATION=true
CONTROL_PARQUET_COPY_ROOT=abfss://rngpub@adlsdnapdevsilver.dfs.core.windows.net/eng511/control_parquet/

# Optional external location roots by environment
DROPZONE_DEV_ROOT=abfss://connect@stcbrpubdzeng511dev.dfs.core.windows.net/
DROPZONE_TST_ROOT=abfss://connect@stcbrpubdzeng511tst.dfs.core.windows.net/
DROPZONE_PRD_ROOT=abfss://connect@stcbrpubdzeng511prd.dfs.core.windows.net/

# Feature branch parity (publisher/runtime defaults)
PUBLISHER_NAME=connect
SILVER_DB_NAME=standardised
SILVER_SUB_FOLDER=standardised
CATALOG_SILVER=eng511_development_silver

# Branch-style mount path defaults
MNT_DROPZONE_ROOT=abfss://rngpub@adlsdnapdevbronze.dfs.core.windows.net/eng511/raw_data/connect
MNT_BRONZE_ROOT=abfss://rngpub@adlsdnapdevbronze.dfs.core.windows.net/eng511
MNT_SILVER_ROOT=abfss://rngpub@adlsdnapdevsilver.dfs.core.windows.net/eng511

# Source registry raw path roots used by this framework
RAW_CONNECT_ROOT=abfss://rngpub@adlsdnapdevbronze.dfs.core.windows.net/eng511/raw_data/connect/
RAW_CONNECT_COUNTRYRISKDET_ROOT=abfss://rngpub@adlsdnapdevbronze.dfs.core.windows.net/eng511/raw_data/connect/cemccountryriskdet/deltaload/
RAW_CONNECT_ITEMMATPLANTREP_ROOT=abfss://rngpub@adlsdnapdevbronze.dfs.core.windows.net/eng511/raw_data/connect/cemcitemmatplantrep/
RAW_CONNECT_MSSREPRECEIVER_ROOT=abfss://rngpub@adlsdnapdevbronze.dfs.core.windows.net/eng511/raw_data/connect/cemcmssrepreceiver/
RAW_CONNECT_MTRLFTSDETAIL_ROOT=abfss://rngpub@adlsdnapdevbronze.dfs.core.windows.net/eng511/raw_data/connect/cemcmtrlftsdetail/
RAW_PIA_COMMONDIMENSIONSPRD_ROOT=abfss://rngpub@adlsdnapdevbronze.dfs.core.windows.net/eng511/raw_data/pia/commondimensionsprd/
RAW_ITEMSUMMARY_ROOT=abfss://rngpub@adlsdnapdevbronze.dfs.core.windows.net/eng511/raw_data/pia/itemsummarypublicprd/
RAW_PIA_COMMONDIM_ITEM_ROOT=abfss://rngpub@adlsdnapdevbronze.dfs.core.windows.net/eng511/raw_data/pia/commondimensions/item
RAW_PIA_COMMONDIM_VALUEBAG_ROOT=abfss://rngpub@adlsdnapdevbronze.dfs.core.windows.net/eng511/raw_data/pia/commondimensions/valuebag
RAW_PIA_COMMONDIM_BAS_ROOT=abfss://rngpub@adlsdnapdevbronze.dfs.core.windows.net/eng511/raw_data/pia/commondimensions/bas
RAW_METADATA_STTM_ROOT=abfss://rngpub@adlsdnapdevbronze.dfs.core.windows.net/eng511/metadata/sttm/
RAW_SAMPLE_SALES_ACCOUNTS_ROOT=abfss://rngpub@adlsdnapdevbronze.dfs.core.windows.net/eng511/raw_data/sales/crm/accounts/

# Incremental cutoff used in source_options_json (POC)
POC_INCREMENTAL_START_TS=2026-04-01T00:00:00Z

# JDBC profile: ikea_erp
IKEA_ERP_JDBC_URL=jdbc:sqlserver://server:1433;databaseName=ERP
IKEA_ERP_JDBC_DRIVER=com.microsoft.sqlserver.jdbc.SQLServerDriver
IKEA_ERP_JDBC_USER=<jdbc_user>
IKEA_ERP_JDBC_PASSWORD=<jdbc_password>

# API profile: ikea_crm
IKEA_CRM_API_BASE_URL=https://api.ikea.example.com
IKEA_CRM_API_TOKEN=<token>

# JDBC profile: oracle_dev
# Maps to: jdbc:oracle:thin:@//<host>:<port>/<service>
# Driver jar required on Databricks cluster: ojdbc11.jar
# Maven: com.oracle.database.jdbc:ojdbc11:21.9.0.0
ORACLE_DEV_HOST=<db_host>
ORACLE_DEV_PORT=1521
ORACLE_DEV_SERVICE=<service_name>
ORACLE_DEV_USER=<your_username>
ORACLE_DEV_PASSWORD=<your_password>
