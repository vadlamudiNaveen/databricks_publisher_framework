{
  "jobs": [
    {
      "name": "framework_initialize_infrastructure_once",
      "description": "One-time Unity Catalog and control/audit table initialization.",
      "max_concurrent_runs": 1,
      "tasks": [
        {
          "task_key": "initialize_framework",
          "notebook_task": {
            "notebook_path": "/Repos/databricks-ingestion-framework/notebooks/05_orchestration/initialize_framework",
            "base_parameters": {
              "config_path": "/Workspace/Repos/databricks-ingestion-framework/config/global_config.yaml"
            }
          }
        }
      ]
    },
    {
      "name": "framework_setup_wizard_once",
      "description": "One-time end-to-end setup verification workflow.",
      "max_concurrent_runs": 1,
      "tasks": [
        {
          "task_key": "setup_wizard",
          "notebook_task": {
            "notebook_path": "/Repos/databricks-ingestion-framework/notebooks/05_orchestration/setup_wizard",
            "base_parameters": {
              "config_path": "/Workspace/Repos/databricks-ingestion-framework/config/global_config.yaml",
              "config_dir": "/Workspace/Repos/databricks-ingestion-framework/config"
            }
          }
        }
      ]
    }
  ]
}
